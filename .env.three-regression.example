# Copy to .env.three-regression and fill in local-only secrets.
# This file stays local and must never be committed.

# -----------------------------------------------------------------------------
# Shared agent credentials
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_BASE=

# -----------------------------------------------------------------------------
# Shared agent home config bootstrap
# -----------------------------------------------------------------------------
THREE_REGRESSION_CLAUDE_BASE_URL=
THREE_REGRESSION_CLAUDE_AUTH_TOKEN=
THREE_REGRESSION_CLAUDE_ATTRIBUTION_HEADER=0

THREE_REGRESSION_CODEX_MODEL_PROVIDER=OpenAI
THREE_REGRESSION_CODEX_MODEL=gpt-5.4
THREE_REGRESSION_CODEX_REVIEW_MODEL=gpt-5.4
THREE_REGRESSION_CODEX_REASONING_EFFORT=xhigh
THREE_REGRESSION_CODEX_DISABLE_RESPONSE_STORAGE=true
THREE_REGRESSION_CODEX_RESPONSES_WEBSOCKETS_V2=false
THREE_REGRESSION_CODEX_CONTEXT_WINDOW=1000000
THREE_REGRESSION_CODEX_AUTO_COMPACT_TOKEN_LIMIT=900000
THREE_REGRESSION_CODEX_BASE_URL=
THREE_REGRESSION_CODEX_OPENAI_API_KEY=
THREE_REGRESSION_CODEX_SUPPRESS_UNSTABLE_WARNING=true

THREE_REGRESSION_OPENCODE_OPENAI_BASE_URL=
THREE_REGRESSION_OPENCODE_OPENAI_API_KEY=
THREE_REGRESSION_OPENCODE_ANTHROPIC_BASE_URL=
THREE_REGRESSION_OPENCODE_ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Shared regression defaults
# -----------------------------------------------------------------------------
THREE_REGRESSION_DEFAULT_CWD=/data/vibe_remote/workdir
THREE_REGRESSION_LOG_LEVEL=INFO
THREE_REGRESSION_LANGUAGE=en

# -----------------------------------------------------------------------------
# Local UI ports
# -----------------------------------------------------------------------------
THREE_REGRESSION_SLACK_PORT=15131
THREE_REGRESSION_DISCORD_PORT=15132
THREE_REGRESSION_FEISHU_PORT=15133

# -----------------------------------------------------------------------------
# Slack regression environment
# -----------------------------------------------------------------------------
THREE_REGRESSION_SLACK_BOT_TOKEN=
THREE_REGRESSION_SLACK_APP_TOKEN=
THREE_REGRESSION_SLACK_CHANNEL=
THREE_REGRESSION_SLACK_BACKEND=opencode
THREE_REGRESSION_SLACK_REQUIRE_MENTION=false
THREE_REGRESSION_SLACK_OPENCODE_AGENT=
THREE_REGRESSION_SLACK_OPENCODE_MODEL=
THREE_REGRESSION_SLACK_OPENCODE_REASONING_EFFORT=
THREE_REGRESSION_SLACK_CLAUDE_AGENT=
THREE_REGRESSION_SLACK_CLAUDE_MODEL=
THREE_REGRESSION_SLACK_CODEX_MODEL=
THREE_REGRESSION_SLACK_CODEX_REASONING_EFFORT=

# -----------------------------------------------------------------------------
# Discord regression environment
# -----------------------------------------------------------------------------
THREE_REGRESSION_DISCORD_BOT_TOKEN=
THREE_REGRESSION_DISCORD_CHANNEL=
THREE_REGRESSION_DISCORD_GUILD_ALLOWLIST=
THREE_REGRESSION_DISCORD_GUILD_DENYLIST=
THREE_REGRESSION_DISCORD_BACKEND=codex
THREE_REGRESSION_DISCORD_REQUIRE_MENTION=false
THREE_REGRESSION_DISCORD_OPENCODE_AGENT=
THREE_REGRESSION_DISCORD_OPENCODE_MODEL=
THREE_REGRESSION_DISCORD_OPENCODE_REASONING_EFFORT=
THREE_REGRESSION_DISCORD_CLAUDE_AGENT=
THREE_REGRESSION_DISCORD_CLAUDE_MODEL=
THREE_REGRESSION_DISCORD_CODEX_MODEL=
THREE_REGRESSION_DISCORD_CODEX_REASONING_EFFORT=

# -----------------------------------------------------------------------------
# Feishu regression environment
# -----------------------------------------------------------------------------
THREE_REGRESSION_FEISHU_APP_ID=
THREE_REGRESSION_FEISHU_APP_SECRET=
THREE_REGRESSION_FEISHU_CHAT_ID=
THREE_REGRESSION_FEISHU_BACKEND=claude
THREE_REGRESSION_FEISHU_REQUIRE_MENTION=false
THREE_REGRESSION_FEISHU_DOMAIN=feishu
THREE_REGRESSION_FEISHU_OPENCODE_AGENT=
THREE_REGRESSION_FEISHU_OPENCODE_MODEL=
THREE_REGRESSION_FEISHU_OPENCODE_REASONING_EFFORT=
THREE_REGRESSION_FEISHU_CLAUDE_AGENT=
THREE_REGRESSION_FEISHU_CLAUDE_MODEL=
THREE_REGRESSION_FEISHU_CODEX_MODEL=
THREE_REGRESSION_FEISHU_CODEX_REASONING_EFFORT=
