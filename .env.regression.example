# Copy to .env.regression and fill in local-only secrets.
# This file stays local and must never be committed.

# -----------------------------------------------------------------------------
# Shared agent credentials
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_BASE=

# -----------------------------------------------------------------------------
# Shared agent home config bootstrap
# -----------------------------------------------------------------------------
REGRESSION_CLAUDE_BASE_URL=
REGRESSION_CLAUDE_AUTH_TOKEN=
REGRESSION_CLAUDE_ATTRIBUTION_HEADER=0

REGRESSION_CODEX_MODEL_PROVIDER=OpenAI
REGRESSION_CODEX_MODEL=gpt-5.4
REGRESSION_CODEX_REVIEW_MODEL=gpt-5.4
REGRESSION_CODEX_REASONING_EFFORT=xhigh
REGRESSION_CODEX_DISABLE_RESPONSE_STORAGE=true
REGRESSION_CODEX_RESPONSES_WEBSOCKETS_V2=false
REGRESSION_CODEX_CONTEXT_WINDOW=1000000
REGRESSION_CODEX_AUTO_COMPACT_TOKEN_LIMIT=900000
REGRESSION_CODEX_BASE_URL=
REGRESSION_CODEX_OPENAI_API_KEY=
REGRESSION_CODEX_SUPPRESS_UNSTABLE_WARNING=true

REGRESSION_OPENCODE_OPENAI_BASE_URL=
REGRESSION_OPENCODE_OPENAI_API_KEY=
REGRESSION_OPENCODE_ANTHROPIC_BASE_URL=
REGRESSION_OPENCODE_ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Shared regression defaults
# -----------------------------------------------------------------------------
REGRESSION_UI_HOST=127.0.0.1
REGRESSION_PORT=15130
REGRESSION_DEFAULT_CWD=/home/avibe/.avibe/workdir
REGRESSION_DEFAULT_BACKEND=opencode
REGRESSION_LOG_LEVEL=INFO
REGRESSION_LANGUAGE=en

# Master/worktree regression does not necessarily carry a packaged release
# manifest, so the regression script prepares Show Runtime from source by
# default. Release/pre-release installs should use the packaged manifest path.
REGRESSION_SHOW_RUNTIME_SOURCE=github-source
REGRESSION_SHOW_RUNTIME_GITHUB_REPO=https://github.com/avibe-bot/vibe-show-runtime.git
REGRESSION_SHOW_RUNTIME_GITHUB_REF=main

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
REGRESSION_SLACK_BOT_TOKEN=
REGRESSION_SLACK_APP_TOKEN=
REGRESSION_SLACK_CHANNEL=
REGRESSION_SLACK_BACKEND=opencode
REGRESSION_SLACK_REQUIRE_MENTION=false
REGRESSION_SLACK_OPENCODE_AGENT=
REGRESSION_SLACK_OPENCODE_MODEL=
REGRESSION_SLACK_OPENCODE_REASONING_EFFORT=
REGRESSION_SLACK_CLAUDE_AGENT=
REGRESSION_SLACK_CLAUDE_MODEL=
REGRESSION_SLACK_CODEX_MODEL=
REGRESSION_SLACK_CODEX_REASONING_EFFORT=

# -----------------------------------------------------------------------------
