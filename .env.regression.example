REGRESSION_DISCORD_REQUIRE_MENTION=false
REGRESSION_DISCORD_OPENCODE_AGENT=
REGRESSION_DISCORD_OPENCODE_MODEL=
REGRESSION_DISCORD_OPENCODE_REASONING_EFFORT=
REGRESSION_DISCORD_CLAUDE_AGENT=
REGRESSION_DISCORD_CLAUDE_MODEL=
REGRESSION_DISCORD_CODEX_MODEL=
REGRESSION_DISCORD_CODEX_REASONING_EFFORT=

# -----------------------------------------------------------------------------
